# Copy this file to `.env.local` for local development, or rely on `.env.production` for builds.
# Vite inlines any variable prefixed with VITE_ into the client bundle at build time.

# Google Apps Script Web App URL that appends waitlist submissions to the sheet.
VITE_WAITLIST_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
